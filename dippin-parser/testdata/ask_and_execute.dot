digraph AskAndExecute {
  rankdir=TB;
  node [fontname="Helvetica"];
  edge [fontname="Helvetica"];
  Start [label="Start", shape="Mdiamond"];
  Exit [label="Exit", shape="Msquare"];
  SetupWorkspace [label="Setup Workspace", shape="parallelogram"];
  AskUser [label="What would you like to do?", shape="hexagon"];
  InterpretRequest [label="Interpret Request", shape="box"];
  ImplementParallel [label="ImplementParallel", shape="component"];
  ImplementClaude [label="Claude Implementation", shape="box"];
  ImplementCodex [label="Codex Implementation", shape="box"];
  ImplementGemini [label="Gemini Implementation", shape="box"];
  ImplementJoin [label="ImplementJoin", shape="tripleoctagon"];
  ValidateBuild [label="Validate Build and Tests", shape="parallelogram"];
  CommitWork [label="Commit Work", shape="box"];
  ReviewParallel [label="ReviewParallel", shape="component"];
  ReviewClaude [label="Claude Review", shape="box"];
  ReviewCodex [label="Codex Review", shape="box"];
  ReviewGemini [label="Gemini Review", shape="box"];
  ReviewsJoin [label="ReviewsJoin", shape="tripleoctagon"];
  CritiquesParallel [label="CritiquesParallel", shape="component"];
  CritiqueClaudeOnCodex [label="Claude Critique of Codex Review", shape="box"];
  CritiqueClaudeOnGemini [label="Claude Critique of Gemini Review", shape="box"];
  CritiqueCodexOnClaude [label="Codex Critique of Claude Review", shape="box"];
  CritiqueCodexOnGemini [label="Codex Critique of Gemini Review", shape="box"];
  CritiqueGeminiOnClaude [label="Gemini Critique of Claude Review", shape="box"];
  CritiqueGeminiOnCodex [label="Gemini Critique of Codex Review", shape="box"];
  CritiquesJoin [label="CritiquesJoin", shape="tripleoctagon"];
  ReviewAnalysis [label="Review Analysis", shape="box"];
  HumanApproval [label="Models disagree. Review the work and decide.", shape="hexagon"];
  ApproveCommit [label="Approve and Commit", shape="box"];
  ReworkInterpret [label="Incorporate Rework Feedback", shape="box"];
  FailureSummary [label="Failure Summary", shape="box"];

  Start -> SetupWorkspace;
  SetupWorkspace -> AskUser;
  AskUser -> InterpretRequest;
  InterpretRequest -> ImplementParallel;
  ImplementParallel -> ImplementClaude;
  ImplementParallel -> ImplementCodex;
  ImplementParallel -> ImplementGemini;
  ImplementClaude -> ImplementJoin;
  ImplementCodex -> ImplementJoin;
  ImplementGemini -> ImplementJoin;
  ImplementJoin -> ValidateBuild;
  ValidateBuild -> CommitWork [condition="outcome = success", label="validated"];
  ValidateBuild -> ImplementClaude [condition="outcome = fail", label="fix_validation", restart="true", style="dashed"];
  CommitWork -> ReviewParallel;
  ReviewParallel -> ReviewClaude;
  ReviewParallel -> ReviewCodex;
  ReviewParallel -> ReviewGemini;
  ReviewClaude -> ReviewsJoin;
  ReviewCodex -> ReviewsJoin;
  ReviewGemini -> ReviewsJoin;
  ReviewsJoin -> CritiquesParallel;
  CritiquesParallel -> CritiqueClaudeOnCodex;
  CritiquesParallel -> CritiqueClaudeOnGemini;
  CritiquesParallel -> CritiqueCodexOnClaude;
  CritiquesParallel -> CritiqueCodexOnGemini;
  CritiquesParallel -> CritiqueGeminiOnClaude;
  CritiquesParallel -> CritiqueGeminiOnCodex;
  CritiqueClaudeOnCodex -> CritiquesJoin;
  CritiqueClaudeOnGemini -> CritiquesJoin;
  CritiqueCodexOnClaude -> CritiquesJoin;
  CritiqueCodexOnGemini -> CritiquesJoin;
  CritiqueGeminiOnClaude -> CritiquesJoin;
  CritiqueGeminiOnCodex -> CritiquesJoin;
  CritiquesJoin -> ReviewAnalysis;
  ReviewAnalysis -> CommitWork [condition="outcome = success", label="pass", restart="true", style="dashed"];
  ReviewAnalysis -> ImplementClaude [condition="outcome = retry", label="rework", restart="true", style="dashed"];
  ReviewAnalysis -> HumanApproval [condition="outcome = disagree", label="disagree"];
  HumanApproval -> ApproveCommit [label="[A] Approve"];
  HumanApproval -> ReworkInterpret [label="[R] Rework"];
  HumanApproval -> FailureSummary [label="[X] Reject"];
  ReworkInterpret -> ImplementParallel [restart="true", style="dashed"];
  ApproveCommit -> Exit;
  FailureSummary -> Exit;
}
